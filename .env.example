# OpenAI API Key (optional - system falls back to template-based analysis without it)
OPENAI_API_KEY=

# LLM Model
LLM_MODEL=gpt-4o-mini

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=infra_docs

# Embedding Models
TEXT_MODEL=all-MiniLM-L6-v2
CLIP_MODEL=ViT-B/32

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
